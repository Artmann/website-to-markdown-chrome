{
  "name": "Website to Markdown",
  "description": "A Chrome extension to convert web pages to Markdown",
  "version": "1.2.0",
  "manifest_version": 3,
  "action": {
    "default_popup": "dist/index.html",
    "default_icon": "icon.png"
  },
  "permissions": ["tabs"],
  "host_permissions": [
    "https://website-to-markdown-serverless.artgaard.workers.dev/*"
  ]
}
